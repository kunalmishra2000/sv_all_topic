//Example #2
                                   //Let us see a 3D packed array now.



module tab;
  bit [2:0][3:0][7:0] a;
  
  initial begin
    a[0]= 32'hface_cafe;
    a[1]= 32'hface_cafe;
    a[2]= 32'hface_cafe;

    
    for(int i=0; i<=2; i++)begin
      $display("a[%0d]=%0h", i,a[i]);
    end
    
  end
  
endmodule
